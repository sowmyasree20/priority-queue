class Solution {
    public int[] numberGame(int[] nums) {
       PriorityQueue<Integer> q=new PriorityQueue<>();
       int n=nums.length;
       int arr[]=new int[n];
       for(int i=0;i<n;i++){
        q.add(nums[i]);
       }
       int j=0;
       while(q.size()>0){
        int a=q.poll();
        int b=q.poll();
        arr[j++]=b;
        arr[j++]=a;
       }
       return arr;
    }
}
